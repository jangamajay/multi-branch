pipeline {
agent any
stages {
stage('Checkout') {
steps {
git 'https://github.com/jangamajay/multi-branch.git'
}
}
stage('Test') {
when {
anyOf {
branch 'main' branch 'DEV' branch 'QA' }
}
steps {
mvn test
''' }
}
stage('Build') {
when {
branch 'main' }
steps {
mvn clean package
''' }
}
stage('Deploy') {
when {
branch 'main' }
steps {
java -jar target/java-sample-21-1.0.0.jar
''' }
}
}
}
