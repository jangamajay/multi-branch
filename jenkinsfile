pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test') {
            when {
                anyOf {
                    branch 'DEV'
                    branch 'QA'
                    branch 'TESTING'
                }
            }
            steps {
                sh 'echo "BUILD SUCCESFULLY"'
            }
        }

        stage('Build') {
            when {
                branch 'main'
            }
            steps {
                sh 'echo "BUILD STAGE"'
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                sh 'echo "DEPLOY STAGE"'
            }
        }
    }
}
